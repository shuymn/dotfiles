{
  "$schema": "https://docs.renovatebot.com/renovate-global-schema.json",
  "platform": "github",
  "repositories": ["shuymn/dotfiles"],
  "requireConfig": "ignored",
  "extends": ["github>shuymn/github-actions#main"],
  "minimumReleaseAge": "1 days",
  "lockFileMaintenance": {
    "schedule": ["at any time"]
  },
  "customDatasources": {
    "cursor-agent": {
      "defaultRegistryUrlTemplate": "https://formulae.brew.sh/api/cask/cursor-cli.json",
      "format": "json",
      "transformTemplates": [
        "{ \"releases\": [{ \"version\": version, \"releaseTimestamp\": $substring(version, 0, 4) & '-' & $substring(version, 5, 2) & '-' & $substring(version, 8, 2) & 'T00:00:00Z' }] }"
      ]
    },
    "pypi-json": {
      "defaultRegistryUrlTemplate": "https://pypi.org/pypi/{{packageName}}/json",
      "format": "json",
      "transformTemplates": [
        "{ \"releases\": $append([], $map($filter($keys(releases), function($v) { $exists($lookup(releases, $v)[0].upload_time) }), function($v) { { \"version\": $v, \"releaseTimestamp\": $lookup(releases, $v)[0].upload_time } })), \"homepage\": info.project_urls.Homepage, \"sourceUrl\": info.project_urls.Repository }"
      ]
    }
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update renovatebot/github-action renovate-version input",
      "managerFilePatterns": ["/^\\.github\\/workflows\\/renovate-run\\.yml$/"],
      "matchStrings": [
        "renovate-version:\\s*(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "datasourceTemplate": "npm",
      "depNameTemplate": "renovate"
    },
    {
      "customType": "regex",
      "description": "Update Nix packages annotated with renovate comments",
      "managerFilePatterns": ["/^nix\\/packages\\/.*\\.nix$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+version = \\\"(?<currentValue>[^\\\"]+)\\\";"
      ]
    },
    {
      "customType": "regex",
      "description": "Track mise go version via golang-version (github-tags lacks releaseTimestamp)",
      "managerFilePatterns": ["/^home\\/dot_config\\/mise\\/config\\.toml$/"],
      "matchStrings": ["\\ngo = \"(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "golang-version",
      "depNameTemplate": "go"
    },
    {
      "customType": "regex",
      "description": "Track mise python version via python-version (github-tags lacks releaseTimestamp)",
      "managerFilePatterns": ["/^home\\/dot_config\\/mise\\/config\\.toml$/"],
      "matchStrings": ["\\npython = \"(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "python-version",
      "depNameTemplate": "python"
    },
    {
      "customType": "regex",
      "description": "Track mise claude version via npm (aqua/github-tags lacks releaseTimestamp)",
      "managerFilePatterns": ["/^home\\/dot_config\\/mise\\/config\\.toml$/"],
      "matchStrings": ["claude = \"(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "npm",
      "depNameTemplate": "@anthropic-ai/claude-code"
    },
    {
      "customType": "regex",
      "description": "Track mise codex version via npm (aqua/github-tags lacks releaseTimestamp)",
      "managerFilePatterns": ["/^home\\/dot_config\\/mise\\/config\\.toml$/"],
      "matchStrings": ["codex = \"(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "npm",
      "depNameTemplate": "@openai/codex"
    },
    {
      "customType": "regex",
      "description": "Track mise tavily-cli version via PyPI JSON API",
      "managerFilePatterns": ["/^home\\/dot_config\\/mise\\/config\\.toml$/"],
      "matchStrings": ["\"pipx:tavily-cli\"\\s*=\\s*\"(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "custom.pypi-json",
      "depNameTemplate": "tavily-cli",
      "versioningTemplate": "pep440"
    },
    {
      "customType": "regex",
      "description": "Track mise microsandbox version via PyPI JSON API",
      "managerFilePatterns": ["/^home\\/dot_config\\/mise\\/config\\.toml$/"],
      "matchStrings": ["\"pipx:microsandbox\"\\s*=\\s*\"(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "custom.pypi-json",
      "depNameTemplate": "microsandbox",
      "versioningTemplate": "pep440"
    },
    {
      "customType": "regex",
      "description": "Track mise cursor-agent version via Homebrew cask API",
      "managerFilePatterns": ["/^home\\/dot_config\\/mise\\/config\\.toml$/"],
      "matchStrings": ["\"http:cursor-agent\"\\s*=\\s*\\{[^}]*version\\s*=\\s*\"(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "custom.cursor-agent",
      "depNameTemplate": "cursor-agent",
      "versioningTemplate": "loose"
    }
  ],
  "packageRules": [
    {
      "description": "Automerge mise minor/patch updates",
      "matchManagers": ["mise"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "Disable mise lookups tracked via regex managers",
      "matchManagers": ["mise"],
      "matchDepNames": ["claude", "codex", "go", "python", "http:cursor-agent", "pipx:tavily-cli", "pipx:microsandbox"],
      "enabled": false
    },
    {
      "description": "Automerge minor/patch for regex-managed mise tools",
      "matchManagers": ["custom.regex"],
      "matchDepNames": ["@anthropic-ai/claude-code", "@openai/codex", "cursor-agent", "tavily-cli", "microsandbox"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "Refresh mise.lock after updates to the tracked mise config",
      "matchFileNames": ["home/dot_config/mise/config.toml"],
      "postUpgradeTasks": {
        "commands": ["mise trust config.toml", "mise lock"],
        "fileFilters": ["home/dot_config/mise/mise.lock"],
        "executionMode": "update",
        "installTools": {
          "mise": {}
        },
        "workingDirTemplate": "{{{packageFileDir}}}"
      }
    }
  ],
  "nix": {
    "enabled": true
  },
  "allowedCommands": ["^mise trust config\\.toml$", "^mise lock$"],
  "allowedUnsafeExecutions": ["mise"]
}
