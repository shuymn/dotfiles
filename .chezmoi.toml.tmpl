{{- $roleFile := joinPath .chezmoi.homeDir ".config" "chezmoi" "nix-role" -}}
{{- $persistedRole := "" -}}
{{- if stat $roleFile -}}
{{-   $persistedRole = include $roleFile | trim -}}
{{- end -}}
{{- $nixRole := env "DOTFILES_NIX_ROLE" | default ($persistedRole | default (index . "nixRole" | default "minimal")) -}}
sourceDir = {{ .chezmoi.workingTree | quote }}
encryption = "age"

[data]
nixRole = {{ $nixRole | quote }}

[age]
identity = "~/.config/age/key.txt"
{{- $ageIdentity := print .chezmoi.homeDir "/.config/age/key.txt" }}
{{- if stat $ageIdentity }}
{{- $ageRecipientScript := print .chezmoi.workingTree "/scripts/age-recipient.sh" }}
{{- $ageRecipient := output "/bin/sh" $ageRecipientScript $ageIdentity }}
recipient = {{ $ageRecipient | trim | quote }}
{{- end }}
